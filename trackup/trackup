#!/usr/bin/env bash
set -euo pipefail

# ==============================================================================
# trackup bootstrap and updater
# ==============================================================================
#
# `trackup` installs one coherent `track` release: the CLI is built from the
# tagged source release, while the backend wrapper and release Compose file come
# from the matching GitHub release assets. Using the same tag for both sides
# keeps the local CLI and the backend image contract aligned.

TRACKUP_HOME="${TRACKUP_HOME:-$HOME/.track}"
TRACKUP_BIN_DIR="${TRACKUP_BIN_DIR:-$TRACKUP_HOME/bin}"
TRACKUP_SHARE_DIR="${TRACKUP_SHARE_DIR:-$TRACKUP_HOME/share}"
TRACKUP_RELEASE_REPOSITORY_URL="https://github.com/popzxc/track"
TRACKUP_RELEASE_REPOSITORY_API_URL="https://api.github.com/repos/popzxc/track"
# This override exists only for the internal `--ref` developer path used by the
# smoke installer. Release installs intentionally stay pinned to the canonical
# upstream repository so tag resolution, asset downloads, and cargo installs all
# resolve one coherent published release.
TRACKUP_REPOSITORY_URL="${TRACKUP_REPOSITORY_URL:-$TRACKUP_RELEASE_REPOSITORY_URL}"
TRACKUP_EXPECTED_COMMIT="${TRACKUP_EXPECTED_COMMIT:-}"

REQUESTED_TAG=""
REQUESTED_REF=""
REQUESTED_VARIANT=""
INSTALL_SOURCE=""
RELEASE_TAG=""
INSTALL_LABEL=""
INSTALL_VARIANT=""
ASSET_BUNDLE_LABEL=""
LOCAL_IMAGE_REF=""
SOURCE_CHECKOUT_DIR=""
TEMP_DIR=""
PATH_STATUS="unchanged"
RELOAD_COMMAND=""
RC_FILE=""

main() {
  parse_args "$@"

  ensure_prerequisites
  prepare_temp_dir
  resolve_install_source
  INSTALL_VARIANT="$(determine_install_variant)"

  if [ "$INSTALL_SOURCE" = "release" ]; then
    download_release_assets
    verify_downloaded_assets
  else
    package_ref_assets
  fi

  install_track_cli
  install_shared_assets
  maybe_configure_path
  print_next_steps
}

print_usage() {
  cat <<'EOF'
Usage:
  trackup
  trackup vX.Y.Z
  trackup X.Y.Z
  trackup --ref <git-ref>

Installs or updates `track` from the tagged release source and shared assets.
`--ref` is an internal developer path that packages the shared assets locally
from the requested checkout and expects the backend image tag to already exist
on the machine.

Examples:
  trackup
  trackup v0.2.0
  trackup --ref main

Environment overrides:
  TRACKUP_HOME        Override the ~/.track root used for installation.
EOF
}

parse_args() {
  while (($# > 0)); do
    case "$1" in
      -h|--help)
        print_usage
        exit 0
        ;;
      --cuda)
        [ -z "$REQUESTED_VARIANT" ] || die "Choose at most one CLI variant."
        REQUESTED_VARIANT="cuda"
        ;;
      --default)
        [ -z "$REQUESTED_VARIANT" ] || die "Choose at most one CLI variant."
        REQUESTED_VARIANT="default"
        ;;
      --ref)
        [ -z "$REQUESTED_REF" ] || die "Choose at most one git ref."
        [ -z "$REQUESTED_TAG" ] || die "Choose either a release tag or --ref."
        shift
        [ $# -gt 0 ] || die "--ref expects a git ref."
        REQUESTED_REF="$1"
        ;;
      --*)
        die "Unknown option: $1"
        ;;
      *)
        [ -z "$REQUESTED_REF" ] || die "Choose either a release tag or --ref."
        if [ -n "$REQUESTED_TAG" ]; then
          die "Expected at most one release argument."
        fi

        REQUESTED_TAG="$1"
        ;;
    esac

    shift
  done

  if [ -n "$REQUESTED_REF" ]; then
    return
  fi

  if [ -n "$REQUESTED_TAG" ] && [ "$REQUESTED_TAG" != "latest" ]; then
    case "$REQUESTED_TAG" in
      v*) ;;
      *) REQUESTED_TAG="v$REQUESTED_TAG" ;;
    esac
  fi
}

ensure_prerequisites() {
  require_command curl
  require_command cargo
  require_command rustc
  require_command jq
  require_command tar
  require_command mktemp
  require_command uname
  require_command git
  require_command docker
  require_command cmake
  require_command clang
  require_any_command "a C compiler" cc gcc clang
  require_any_command "a C++ compiler" c++ g++ clang++

  if ! command -v sha256sum >/dev/null 2>&1 && ! command -v shasum >/dev/null 2>&1; then
    die "Missing a SHA-256 tool. Install either `sha256sum` or `shasum` and rerun trackup."
  fi

  if ! docker compose version >/dev/null 2>&1; then
    die "Docker Compose is required. Install a Docker build that includes `docker compose`."
  fi
}

resolve_install_source() {
  if [ -n "$REQUESTED_REF" ]; then
    INSTALL_SOURCE="ref"
    prepare_ref_checkout
    return
  fi

  INSTALL_SOURCE="release"
  RELEASE_TAG="$(resolve_release_tag)"
  INSTALL_LABEL="$RELEASE_TAG"
  ASSET_BUNDLE_LABEL="$RELEASE_TAG"
}

resolve_release_tag() {
  local response

  if [ -z "$REQUESTED_TAG" ] || [ "$REQUESTED_TAG" = "latest" ]; then
    response="$(github_api_get "${TRACKUP_RELEASE_REPOSITORY_API_URL}/releases/latest")"
  else
    response="$(github_api_get "${TRACKUP_RELEASE_REPOSITORY_API_URL}/releases/tags/${REQUESTED_TAG}")"
  fi

  jq -er '.tag_name' <<<"$response" >/dev/null || die "GitHub did not return a release tag."
  jq -r '.tag_name' <<<"$response"
}

prepare_ref_checkout() {
  local resolved_commit
  local short_ref

  SOURCE_CHECKOUT_DIR="${TEMP_DIR}/source"

  git clone "$TRACKUP_REPOSITORY_URL" "$SOURCE_CHECKOUT_DIR" >/dev/null 2>&1 \
    || die "Could not clone ${TRACKUP_REPOSITORY_URL}."

  if ! git -C "$SOURCE_CHECKOUT_DIR" checkout --detach "$REQUESTED_REF" >/dev/null 2>&1; then
    git -C "$SOURCE_CHECKOUT_DIR" fetch --depth 1 origin "$REQUESTED_REF" >/dev/null 2>&1 \
      || die "Could not fetch ref ${REQUESTED_REF} from ${TRACKUP_REPOSITORY_URL}."
    git -C "$SOURCE_CHECKOUT_DIR" checkout --detach FETCH_HEAD >/dev/null 2>&1 \
      || die "Could not check out ref ${REQUESTED_REF} from ${TRACKUP_REPOSITORY_URL}."
  fi

  short_ref="$(
    git -C "$SOURCE_CHECKOUT_DIR" rev-parse --short HEAD 2>/dev/null
  )" || die "Could not resolve the checked-out commit for ${REQUESTED_REF}."
  resolved_commit="$(
    git -C "$SOURCE_CHECKOUT_DIR" rev-parse HEAD 2>/dev/null
  )" || die "Could not resolve the full commit for ${REQUESTED_REF}."

  if [ -n "$TRACKUP_EXPECTED_COMMIT" ] && [ "$resolved_commit" != "$TRACKUP_EXPECTED_COMMIT" ]; then
    die "Ref ${REQUESTED_REF} resolved to ${resolved_commit}, but ${TRACKUP_EXPECTED_COMMIT} was expected."
  fi

  INSTALL_LABEL="ref ${REQUESTED_REF} (${short_ref})"
  ASSET_BUNDLE_LABEL="ref-${short_ref}"
  LOCAL_IMAGE_REF="${TRACKUP_IMAGE_REF:-track-local:${short_ref}}"
}

determine_install_variant() {
  local os
  local arch

  os="$(uname -s)"
  arch="$(uname -m)"

  case "${os}:${arch}" in
    Linux:x86_64|Linux:amd64)
      if [ -n "$REQUESTED_VARIANT" ]; then
        printf '%s\n' "$REQUESTED_VARIANT"
        return
      fi

      if [ -r /dev/tty ] && [ -w /dev/tty ]; then
        prompt_install_variant
        return
      fi

      printf 'No interactive terminal detected; installing the default CLI build.\n' >&2
      printf '%s\n' "default"
      ;;
    *)
      if [ "$REQUESTED_VARIANT" = "cuda" ]; then
        die "--cuda is only available on Linux x86_64 and requires a local CUDA toolkit installation."
      fi

      printf '%s\n' "default"
      ;;
  esac
}

prompt_install_variant() {
  local response

  # `trackup` is commonly run via `curl ... | bash`, so stdin is the script
  # body rather than the user's terminal. Prompting through /dev/tty keeps the
  # installer interactive without requiring awkward `bash -s -- ...` arguments.
  printf '\nSelect the track CLI build to install for %s:\n' "$INSTALL_LABEL" > /dev/tty
  printf '  1) Default\n' > /dev/tty
  printf '     Portable build with no CUDA requirement.\n' > /dev/tty
  printf '  2) CUDA-accelerated\n' > /dev/tty
  printf '     Linux x86_64 only. Requires a local CUDA toolkit installation.\n' > /dev/tty

  while true; do
    printf 'Select [1/2] (default 1): ' > /dev/tty
    IFS= read -r response < /dev/tty || break

    case "${response:-1}" in
      1|"")
        printf '%s\n' "default"
        return
        ;;
      2)
        printf '%s\n' "cuda"
        return
        ;;
      *)
        printf 'Enter 1 or 2.\n' > /dev/tty
        ;;
    esac
  done

  printf '%s\n' "default"
}

prepare_temp_dir() {
  TEMP_DIR="$(mktemp -d)"
  trap cleanup_temp_dir EXIT INT TERM
}

download_release_assets() {
  local shared_asset
  local checksum_asset
  local base_url

  shared_asset="$(shared_asset_name)"
  checksum_asset="$(checksum_asset_name)"
  base_url="${TRACKUP_RELEASE_REPOSITORY_URL}/releases/download/${RELEASE_TAG}"

  download_file "${base_url}/${shared_asset}" "${TEMP_DIR}/${shared_asset}"
  download_file "${base_url}/${checksum_asset}" "${TEMP_DIR}/${checksum_asset}"
}

package_ref_assets() {
  local packaged_archive
  local track_version

  track_version="$(workspace_version_from_checkout "$SOURCE_CHECKOUT_DIR")"
  (
    cd "$SOURCE_CHECKOUT_DIR"
    TRACK_VERSION="$track_version" \
      TRACK_ASSET_LABEL="$ASSET_BUNDLE_LABEL" \
      TRACK_IMAGE_REF="$LOCAL_IMAGE_REF" \
      bash ./trackup/package-release-assets.sh
  ) || die "Could not package shared assets for ${REQUESTED_REF}."

  packaged_archive="${SOURCE_CHECKOUT_DIR}/dist/$(shared_asset_name)"
  [ -f "$packaged_archive" ] || die "Local packaging did not produce $(shared_asset_name)."
  cp "$packaged_archive" "${TEMP_DIR}/$(shared_asset_name)"
}

workspace_version_from_checkout() {
  local checkout_dir
  local version

  checkout_dir="$1"
  version="$(
    awk '
      /^\[workspace\.package\]$/ { in_workspace_package = 1; next }
      /^\[/ { if (in_workspace_package) exit }
      in_workspace_package && $1 == "version" {
        gsub(/"/, "", $3)
        print $3
        exit
      }
    ' "${checkout_dir}/Cargo.toml"
  )"

  [ -n "$version" ] || die "Could not read the workspace version from ${checkout_dir}/Cargo.toml."
  printf '%s\n' "$version"
}

verify_downloaded_assets() {
  local checksum_file

  checksum_file="${TEMP_DIR}/$(checksum_asset_name)"
  verify_file_checksum "$checksum_file" "$(shared_asset_name)"
}

install_track_cli() {
  local cargo_install_args
  local cargo_install_root
  local install_target_description
  local staged_track_binary

  # Reinstall the requested binary even when the git tag is unchanged so users
  # can switch between the default and CUDA builds without manual cleanup.
  # Stage the cargo install into a temporary root first so TRACKUP_BIN_DIR
  # remains the single source of truth for where the final `track` binary lands.
  cargo_install_root="${TEMP_DIR}/cargo-install-root"
  staged_track_binary="${cargo_install_root}/bin/track"
  cargo_install_args=(
    cargo install
    --root "$cargo_install_root"
    --locked
    --force
    --bin track
  )

  if [ "$INSTALL_VARIANT" = "cuda" ]; then
    require_command nvcc
    cargo_install_args+=(--features cuda)
  fi

  if [ "$INSTALL_SOURCE" = "release" ]; then
    cargo_install_args+=(
      --git "$TRACKUP_RELEASE_REPOSITORY_URL"
      --tag "$RELEASE_TAG"
      track-cli
    )
    install_target_description="$RELEASE_TAG"
  else
    cargo_install_args+=(--path "${SOURCE_CHECKOUT_DIR}/crates/track-cli")
    install_target_description="ref ${REQUESTED_REF}"
  fi

  "${cargo_install_args[@]}" || die "Could not install track from ${install_target_description}."
  [ -f "$staged_track_binary" ] || die "cargo install did not produce the expected `track` binary."
  install_file "$staged_track_binary" "$TRACKUP_BIN_DIR/track" 0755
}

install_shared_assets() {
  local shared_extract_dir
  local shared_trackup
  local shared_backend
  local shared_compose

  mkdir -p "$TRACKUP_BIN_DIR" "$TRACKUP_SHARE_DIR"

  shared_extract_dir="${TEMP_DIR}/shared"
  mkdir -p "$shared_extract_dir"

  tar -xzf "${TEMP_DIR}/$(shared_asset_name)" -C "$shared_extract_dir"

  shared_trackup="${shared_extract_dir}/$(shared_asset_stem)/trackup"
  shared_backend="${shared_extract_dir}/$(shared_asset_stem)/track-backend"
  shared_compose="${shared_extract_dir}/$(shared_asset_stem)/track-backend.compose.yaml"

  [ -f "$shared_trackup" ] || die "The shared asset bundle did not contain `trackup`."
  [ -f "$shared_backend" ] || die "The shared asset bundle did not contain `track-backend`."
  [ -f "$shared_compose" ] || die "The shared asset bundle did not contain the release compose file."

  install_file "$shared_trackup" "$TRACKUP_BIN_DIR/trackup" 0755
  install_file "$shared_backend" "$TRACKUP_BIN_DIR/track-backend" 0755
  install_file "$shared_compose" "$TRACKUP_SHARE_DIR/track-backend.compose.yaml" 0644
}

maybe_configure_path() {
  local default_bin_dir
  local shell_name
  local path_line

  default_bin_dir="$HOME/.track/bin"
  if path_contains "$TRACKUP_BIN_DIR"; then
    PATH_STATUS="active"
    return
  fi

  if [ "$TRACKUP_BIN_DIR" != "$default_bin_dir" ]; then
    PATH_STATUS="manual"
    return
  fi

  shell_name="$(basename "${SHELL:-}")"
  case "$shell_name" in
    zsh)
      RC_FILE="${ZDOTDIR:-$HOME}/.zshrc"
      RELOAD_COMMAND="source \"$RC_FILE\""
      path_line='export PATH="$HOME/.track/bin:$PATH"'
      ;;
    bash)
      if [ -f "$HOME/.bash_profile" ] && [ ! -f "$HOME/.bashrc" ]; then
        RC_FILE="$HOME/.bash_profile"
      else
        RC_FILE="$HOME/.bashrc"
      fi

      RELOAD_COMMAND="source \"$RC_FILE\""
      path_line='export PATH="$HOME/.track/bin:$PATH"'
      ;;
    fish)
      RC_FILE="${XDG_CONFIG_HOME:-$HOME/.config}/fish/config.fish"
      RELOAD_COMMAND="source \"$RC_FILE\""
      path_line='fish_add_path "$HOME/.track/bin"'
      ;;
    *)
      PATH_STATUS="manual"
      return
      ;;
  esac

  mkdir -p "$(dirname "$RC_FILE")"
  touch "$RC_FILE"

  if grep -Fqs '.track/bin' "$RC_FILE"; then
    PATH_STATUS="configured"
    return
  fi

  {
    printf '\n'
    printf '# Add track tools to PATH.\n'
    printf '%s\n' "$path_line"
  } >>"$RC_FILE"

  PATH_STATUS="updated"
}

print_next_steps() {
  printf 'Installed track %s (%s build).\n' "$INSTALL_LABEL" "$INSTALL_VARIANT"
  printf 'CLI: %s\n' "$TRACKUP_BIN_DIR/track"
  printf 'Backend wrapper: %s\n' "$TRACKUP_BIN_DIR/track-backend"
  printf 'Compose file: %s\n' "$TRACKUP_SHARE_DIR/track-backend.compose.yaml"
  if [ "$INSTALL_SOURCE" = "ref" ]; then
    printf 'Backend image: %s\n' "$LOCAL_IMAGE_REF"
  fi

  case "$PATH_STATUS" in
    active)
      printf '\nThe current shell already includes %s in PATH.\n' "$TRACKUP_BIN_DIR"
      printf 'Next:\n'
      printf '  track-backend up -d\n'
      ;;
    updated)
      printf '\nReload your shell to pick up %s.\n' "$TRACKUP_BIN_DIR"
      printf 'Run:\n'
      printf '  %s\n' "$RELOAD_COMMAND"
      printf '\nThen start or refresh the backend:\n'
      printf '  track-backend up -d\n'
      ;;
    configured)
      printf '\nA shell startup file already references %s.\n' "$TRACKUP_BIN_DIR"
      printf 'Reload your shell before using the installed commands:\n'
      printf '  %s\n' "$RELOAD_COMMAND"
      printf '\nThen start or refresh the backend:\n'
      printf '  track-backend up -d\n'
      ;;
    manual)
      printf '\nAdd %s to PATH manually.\n' "$TRACKUP_BIN_DIR"
      printf 'For POSIX-style shells:\n'
      printf '  export PATH="%s:$PATH"\n' "$TRACKUP_BIN_DIR"
      printf '\nThen start or refresh the backend:\n'
      printf '  %s up -d\n' "$TRACKUP_BIN_DIR/track-backend"
      ;;
  esac

  printf 'Open: http://127.0.0.1:3210\n'
  printf '\nThe shipped backend binds to 127.0.0.1 by default because it has no authentication layer.\n'
  printf 'Only expose it beyond localhost if you are intentionally placing it behind your own network controls.\n'
  printf 'Example override:\n'
  printf '  TRACK_WEB_BIND_HOST=0.0.0.0 track-backend up -d\n'
}

shared_asset_stem() {
  printf 'trackup-assets-%s\n' "$ASSET_BUNDLE_LABEL"
}

shared_asset_name() {
  printf '%s.tar.gz\n' "$(shared_asset_stem)"
}

checksum_asset_name() {
  printf 'track-%s-sha256sums.txt\n' "$RELEASE_TAG"
}

download_file() {
  local url
  local target

  url="$1"
  target="$2"

  curl -fsSL "$url" -o "$target" || die "Could not download ${url}."
}

verify_file_checksum() {
  local checksum_file
  local asset_name
  local expected
  local actual

  checksum_file="$1"
  asset_name="$2"
  expected="$(expected_checksum_for "$checksum_file" "$asset_name")"
  actual="$(hash_file "${TEMP_DIR}/${asset_name}")"

  if [ "$expected" != "$actual" ]; then
    die "Checksum verification failed for ${asset_name}."
  fi
}

expected_checksum_for() {
  local checksum_file
  local asset_name
  local checksum

  checksum_file="$1"
  asset_name="$2"
  checksum="$(
    awk -v asset_name="$asset_name" '
      {
        file_path = $2
        sub(/^dist\//, "", file_path)
        if (file_path == asset_name) {
          print $1
          exit
        }
      }
    ' "$checksum_file"
  )"

  [ -n "$checksum" ] || die "Could not find a checksum entry for ${asset_name}."
  printf '%s\n' "$checksum"
}

hash_file() {
  local file_path

  file_path="$1"

  if command -v sha256sum >/dev/null 2>&1; then
    sha256sum "$file_path" | awk '{print $1}'
    return
  fi

  shasum -a 256 "$file_path" | awk '{print $1}'
}

install_file() {
  local source
  local target
  local mode
  local target_dir
  local temp_target

  source="$1"
  target="$2"
  mode="$3"
  target_dir="$(dirname "$target")"
  temp_target="${target}.tmp.$$"

  mkdir -p "$target_dir"
  cp "$source" "$temp_target"
  chmod "$mode" "$temp_target"
  mv -f "$temp_target" "$target"
}

path_contains() {
  local candidate

  candidate="$1"
  case ":$PATH:" in
    *":${candidate}:"*) return 0 ;;
    *) return 1 ;;
  esac
}

require_any_command() {
  local description="$1"
  shift

  for command_name in "$@"; do
    if command -v "$command_name" >/dev/null 2>&1; then
      return
    fi
  done

  die "Missing ${description}. Install one of: $*."
}

github_api_get() {
  local url

  url="$1"

  if [ -n "${GITHUB_TOKEN:-}" ]; then
    curl -fsSL \
      -H "Accept: application/vnd.github+json" \
      -H "Authorization: Bearer ${GITHUB_TOKEN}" \
      "$url" || die "Could not query GitHub API at ${url}."
    return
  fi

  curl -fsSL -H "Accept: application/vnd.github+json" "$url" || die "Could not query GitHub API at ${url}."
}

require_command() {
  local command_name

  command_name="$1"
  command -v "$command_name" >/dev/null 2>&1 || die "Missing required command: ${command_name}."
}

cleanup_temp_dir() {
  if [ -n "$TEMP_DIR" ] && [ -d "$TEMP_DIR" ]; then
    rm -rf "$TEMP_DIR"
  fi
}

die() {
  printf 'trackup: %s\n' "$1" >&2
  exit 1
}

main "$@"

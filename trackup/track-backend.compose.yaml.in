services:
  track-web:
    image: ghcr.io/popzxc/track:__TRACK_VERSION__
    # The release image is prebuilt, so it cannot bake in the caller's UID/GID
    # the way the repository-local development compose file does. Running the
    # container as the host user keeps the backend state bind mount writable.
    user: "${TRACK_UID:-1000}:${TRACK_GID:-1000}"
    ports:
      - "${TRACK_WEB_PORT:-3210}:3210"
    environment:
      PORT: "3210"
      TRACK_STATE_DIR: /home/track/backend-state
      TRACK_LEGACY_ROOT: /home/track/legacy-home/.track
      TRACK_LEGACY_CONFIG_PATH: /home/track/legacy-home/.config/track/config.json
    volumes:
      - type: bind
        source: ${HOME}/.track/backend
        target: /home/track/backend-state
        bind:
          create_host_path: true
      - type: bind
        source: ${HOME}
        target: /home/track/legacy-home
        read_only: true

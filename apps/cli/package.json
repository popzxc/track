{
  "name": "@track/cli",
  "version": "0.1.0",
  "type": "module",
  "bin": {
    "track": "./dist/index.js"
  },
  "scripts": {
    "build": "bun build ./src/index.ts --outdir ./dist --target bun",
    "dev": "bun run ./src/index.ts",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@track/core": "workspace:*",
    "@track/shared": "workspace:*"
  }
}

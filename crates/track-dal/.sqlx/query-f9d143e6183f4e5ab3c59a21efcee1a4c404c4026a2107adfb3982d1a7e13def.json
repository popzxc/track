  "query": "\n                SELECT\n                    id AS \"id!\",\n                    project AS \"project!\",\n                    priority AS \"priority!\",\n                    status AS \"status!\",\n                    description AS \"description!\",\n                    created_at AS \"created_at!\",\n                    updated_at AS \"updated_at!\",\n                    source AS \"source?\"\n                FROM tasks\n                WHERE (?1 = 1 OR status = 'open')\n                ORDER BY created_at DESC\n                ",

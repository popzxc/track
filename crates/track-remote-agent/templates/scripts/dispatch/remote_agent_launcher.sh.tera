#!/usr/bin/env bash
set -e
{% if shell_prelude %}{{ shell_prelude }}{% endif %}
set -eu
RUN_DIR="$1"
WORKTREE_PATH="$2"
printf '%s\n' "$$" > "$RUN_DIR/{{ launcher_pid_file }}"
cancel_run() {
  if [ -f "$RUN_DIR/{{ codex_pid_file }}" ]; then
    CODEX_PID="$(tr -d '[:space:]' < "$RUN_DIR/{{ codex_pid_file }}")"
    if [ -n "$CODEX_PID" ] && kill -0 "$CODEX_PID" 2>/dev/null; then
      kill "$CODEX_PID" 2>/dev/null || true
    fi
  fi
  printf 'canceled\n' > "$RUN_DIR/{{ status_file }}"
  date -u +%Y-%m-%dT%H:%M:%SZ > "$RUN_DIR/{{ finished_at_file }}"
  exit 130
}
trap cancel_run TERM INT
printf 'running\n' > "$RUN_DIR/{{ status_file }}"
{{ agent_command }}CODEX_PID="$!"
printf '%s\n' "$CODEX_PID" > "$RUN_DIR/{{ codex_pid_file }}"
if wait "$CODEX_PID"; then
  printf 'completed\n' > "$RUN_DIR/{{ status_file }}"
else
  EXIT_CODE="$?"
  CURRENT_STATUS="$(tr -d '[:space:]' < "$RUN_DIR/{{ status_file }}" 2>/dev/null || true)"
  if [ "$CURRENT_STATUS" != "canceled" ] && [ "$EXIT_CODE" -ne 130 ]; then
    printf 'launcher_failed\n' > "$RUN_DIR/{{ status_file }}"
  fi
fi
date -u +%Y-%m-%dT%H:%M:%SZ > "$RUN_DIR/{{ finished_at_file }}"

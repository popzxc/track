---
source: crates/track-remote-agent/src/scripts/dispatch/remote_agent_launcher.rs
expression: launcher
---
#!/usr/bin/env bash
set -e
export PATH="$HOME/.local/bin:$PATH"

set -eu
RUN_DIR="$1"
WORKTREE_PATH="$2"
printf '%s\n' "$$" > "$RUN_DIR/launcher.pid"
cancel_run() {
  if [ -f "$RUN_DIR/codex.pid" ]; then
    CODEX_PID="$(tr -d '[:space:]' < "$RUN_DIR/codex.pid")"
    if [ -n "$CODEX_PID" ] && kill -0 "$CODEX_PID" 2>/dev/null; then
      kill "$CODEX_PID" 2>/dev/null || true
    fi
  fi
  printf 'canceled\n' > "$RUN_DIR/status.txt"
  date -u +%Y-%m-%dT%H:%M:%SZ > "$RUN_DIR/finished-at.txt"
  exit 130
}
trap cancel_run TERM INT
printf 'running\n' > "$RUN_DIR/status.txt"
SCHEMA_CONTENT="$(tr -d '\n' < "$RUN_DIR/result-schema.json")"
cd "$WORKTREE_PATH"
claude -p --dangerously-skip-permissions --add-dir "$WORKTREE_PATH" --output-format json --json-schema "$SCHEMA_CONTENT" < "$RUN_DIR/prompt.md" > "$RUN_DIR/result.json" 2> "$RUN_DIR/stderr.log" &
CODEX_PID="$!"
printf '%s\n' "$CODEX_PID" > "$RUN_DIR/codex.pid"
if wait "$CODEX_PID"; then
  printf 'completed\n' > "$RUN_DIR/status.txt"
else
  EXIT_CODE="$?"
  CURRENT_STATUS="$(tr -d '[:space:]' < "$RUN_DIR/status.txt" 2>/dev/null || true)"
  if [ "$CURRENT_STATUS" != "canceled" ] && [ "$EXIT_CODE" -ne 130 ]; then
    printf 'launcher_failed\n' > "$RUN_DIR/status.txt"
  fi
fi
date -u +%Y-%m-%dT%H:%M:%SZ > "$RUN_DIR/finished-at.txt"
